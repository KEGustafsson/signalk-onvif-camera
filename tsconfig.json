{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowUmdGlobalAccess": true,
    "moduleDetection": "force",
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "vite.config.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "lib/**/*.ts",
    "test/**/*.ts",
    "test/**/*.d.ts"
  ],
  "exclude": [
    "public",
    "dist",
    "coverage",
    "node_modules"
  ]
}
