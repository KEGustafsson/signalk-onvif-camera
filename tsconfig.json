{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM"],
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "jest", "jquery"]
  },
  "include": [
    "index.ts",
    "lib/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "dist",
    "public"
  ]
}
