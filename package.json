  },
  "author": "Karl-Erik Gustafsson",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "vite": "^6.0.5"
  }
