{
  "name": "signalk-onvif-camera",
  "version": "1.0.0",
  "description": "Signal K Onvif Camera Interface",
  "main": "index.js",
  "files": [
    "index.js",
    "lib/",
    "public/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "clean": "node -e \"require('fs').rmSync('./public',{recursive:true,force:true})\"",
    "dev": "vite",
