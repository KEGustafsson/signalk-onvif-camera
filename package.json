{
  "name": "signalk-onvif-camera",
  "version": "1.1.0",
  "description": "Signal K Onvif Camera Interface",
  "main": "dist/index.js",
  "files": [
    "dist/index.js",
    "dist/lib/",
    "dist/src/",
    "public/",
    "doc/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "npm run build:test && node ./dist/test/prepare-jest-runtime.js && node ./node_modules/jest-cli/bin/jest.js --coverage --runInBand",
    "test:watch": "npm run build:test && node ./dist/test/prepare-jest-runtime.js && node ./node_modules/jest-cli/bin/jest.js --watch",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.strict.json",
    "lint:fix": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.strict.json",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "clean": "node -e \"require('fs').rmSync('./dist',{recursive:true,force:true});require('fs').rmSync('./public/index.js',{force:true});require('fs').rmSync('./public/index.js.map',{force:true});require('fs').rmSync('./public/index.html',{force:true});require('fs').rmSync('./public/style.css',{force:true})\"",
    "dev": "vite",
    "build:server": "tsc -p tsconfig.build.json",
    "build:test": "npm run clean && tsc -p tsconfig.test.json",
    "build": "npm run clean && npm run build:server && npm run build:web",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.strict.json",
    "build:web": "tsc -p tsconfig.web.json && node -e \"const fs=require('fs'); fs.copyFileSync('src/index.html','public/index.html'); fs.copyFileSync('src/style.css','public/style.css');\""
  },
  "signalk": {
    "appIcon": "./icons/icon-72x72.png",
    "displayName": "Signalk-onvif-camera"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KEGustafsson/signalk-onvif-camera"
  },
  "author": "Karl-Erik Gustafsson",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "vite": "^6.0.5",
    "typescript": "^5.8.2"
  },
  "jest": {
    "rootDir": "dist",
    "testEnvironment": "node",
    "coverageDirectory": "../coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "node"
    ],
    "collectCoverageFrom": [
      "index.js",
      "lib/**/*.js",
      "src/server/**/*.js",
      "src/onvif/**/*.js",
      "!lib/node-onvif.js",
      "!src/index.js"
    ],
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "verbose": true
  }
}
